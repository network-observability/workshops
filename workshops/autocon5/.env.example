# AutoCon5 workshop environment.
# Copy this to `.env` in the same directory and edit as needed.
#
# `docker compose` automatically loads `.env` from the directory it's run from,
# and `nobs autocon5 ...` cd's into this folder before invoking compose.

# ---------------------------------------------------------------------------
# Image pins (optional). Leave commented to use the defaults baked into the
# compose file.
# ---------------------------------------------------------------------------
# SONDA_IMAGE=ghcr.io/davidban77/sonda:1.3.0
# PROMETHEUS_IMAGE=docker.io/prom/prometheus:v2.52.0
# LOKI_IMAGE=docker.io/grafana/loki:3.1.1
# GRAFANA_IMAGE=docker.io/grafana/grafana:10.4.4
# ALERTMANAGER_IMAGE=docker.io/prom/alertmanager:v0.26.0
# TELEGRAF_IMAGE=docker.io/telegraf:1.31
# INFRAHUB_IMAGE=registry.opsmill.io/opsmill/infrahub:1.1

# ---------------------------------------------------------------------------
# Grafana admin credentials. Override for production-ish demos.
# ---------------------------------------------------------------------------
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# ---------------------------------------------------------------------------
# Infrahub bootstrap. The default token below is used by `nobs autocon5 load-infrahub`
# and by Grafana's GraphQL datasource. The token is seeded into Infrahub on
# first boot via INFRAHUB_INITIAL_ADMIN_TOKEN, so changing this here changes
# both ends consistently.
# ---------------------------------------------------------------------------
INFRAHUB_ADDRESS=http://infrahub-server:8000
INFRAHUB_API_TOKEN=06438eb2-8019-4776-878c-0941b1f1285d

# ---------------------------------------------------------------------------
# Sonda control-plane endpoint. Used by `nobs autocon5 flap-interface`,
# `nobs autocon5 maintenance`, and Prefect flow annotations to POST events
# through sonda's `/events` API instead of pushing to Loki directly. Auth
# is opt-in: set SONDA_API_KEY to a bearer value to require it on all
# /events and /scenarios requests; leave empty for the default public mode.
# ---------------------------------------------------------------------------
SONDA_SERVER_URL=http://localhost:8085
SONDA_API_KEY=

# URL sonda's `/events` handler uses to forward log events to Loki. Lives
# inside the compose network — `loki` is the service hostname, 3001 the
# port. Distinct from any host-side Loki URL (`http://localhost:3001`)
# the CLI uses to query Loki directly.
SONDA_LOKI_SINK_URL=http://loki:3001

# ---------------------------------------------------------------------------
# AI-assisted troubleshooting toggle (Part 3).
# When ENABLE_AI_RCA=true, the Prefect quarantine flow calls an LLM with the
# evidence bundle (metrics + logs + SoT) and annotates the result back to
# Loki. Falls back to a clear "AI RCA disabled" annotation otherwise so the
# workflow still runs end-to-end without a token.
# ---------------------------------------------------------------------------
ENABLE_AI_RCA=false
AI_RCA_PROVIDER=openai            # openai | anthropic
AI_RCA_MODEL=gpt-4o-mini          # for anthropic, e.g. claude-haiku-4-5-20251001
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
